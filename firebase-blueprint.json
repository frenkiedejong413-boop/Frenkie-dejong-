{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Playlist": {
      "title": "User Playlist",
      "description": "A collection of songs created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "songs": {
          "type": "array",
          "items": { "$ref": "#/entities/PlaylistSong" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "songs"]
    },
    "PlaylistSong": {
      "title": "Playlist Song",
      "description": "A song reference within a playlist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "coverUrl": { "type": "string" }
      },
      "required": ["id", "title", "artist"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User created playlists"
    }
  }
}
